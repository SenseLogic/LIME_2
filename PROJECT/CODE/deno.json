{
  "nodeModulesDir": "manual",
  "lock": false,
  "tasks": {
    "check": "deno lint . && deno check vite.config.ts utils.ts client.ts build-scss.ts routes/_error.tsx",
    "dev": "deno task build-scss && vite",
    "build": "deno task build-scss && vite build",
    "start": "deno serve -A _fresh/server.js",
    "preview": "deno serve -A _fresh/server.js",
    "update": "deno run -A -r jsr:@fresh/update@^2.3.3 .",
    "build-scss": "deno run --allow-read --allow-write --allow-env build-scss.ts",
    "build-scss:watch": "deno run --allow-read --allow-write --allow-env build-scss.ts --watch"
  },
  "lint": {
    "rules": {
      "tags": ["fresh", "recommended"],
      "exclude": ["prefer-const", "no-window", "no-explicit-any", "no-unused-vars"]
    }
  },
  "exclude": ["**/_fresh/*"],
  "imports": {
    "@std/dotenv": "jsr:@std/dotenv@^0.224.0",
    "@std/http": "jsr:@std/http@^1.0.0",
    "fresh": "jsr:@fresh/core@^2.3.3",
    "preact": "npm:preact@^10.29.1",
    "preact/jsx-runtime": "npm:preact@^10.29.1/jsx-runtime",
    "preact/hooks": "npm:preact@^10.29.1/hooks",
    "@preact/signals": "npm:@preact/signals@^2.9.0",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1.1.2",
    "vite": "npm:vite@^7.1.3",
    "@types/babel__core": "npm:@types/babel__core@^7.20.5",
    "@supabase/ssr": "npm:@supabase/ssr@^0.8.0",
    "resend": "npm:resend@^6.7.0",
    "sharp": "npm:sharp@0.34.5",
    "stripe": "npm:stripe@^20.2.0",
    "senselogic-geo": "npm:senselogic-geo@0.1.0",
    "senselogic-gson-file": "jsr:@senselogic/senselogic-gson-file@^0.4.0",
    "senselogic-lingo": "npm:senselogic-lingo@0.1.8",
    "senselogic-opus": "npm:senselogic-opus@0.1.1",
    "senselogic-iota": "npm:senselogic-iota@0.1.0",
    "senselogic-pika": "npm:senselogic-pika@0.1.0",
    "sass": "npm:sass@1.69.5"
  },
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.asynciterable",
      "dom.iterable",
      "deno.ns"
    ],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ],
    "types": [
      "vite/client"
    ],
    "noImplicitAny": false
  }
}
